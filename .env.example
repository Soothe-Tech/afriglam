# AfriGlam env vars. Copy to .env.local for local dev; set in Vercel for production.

# Client (Vite) - safe to expose in the browser
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_public_anon_key
VITE_GEMINI_API_KEY=your_gemini_key

# Server (Vercel API routes) - never expose to the browser
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
PAYMENT_WEBHOOK_SECRET=your_webhook_secret
PAYSTACK_SECRET_KEY=sk_live_or_test_replace_me
# PAYSTACK_WEBHOOK_SECRET=optional_dedicated_paystack_webhook_secret
STRIPE_SECRET_KEY=sk_live_or_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
APP_ORIGIN=https://your-app.vercel.app
